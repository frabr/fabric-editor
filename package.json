{
  "name": "@apibots-io/fabric-editor",
  "version": "1.0.1",
  "description": "Fabric.js-based image editor with layers, clipping, and frame support",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "fabric": "^6.0.0"
  },
  "devDependencies": {
    "fabric": "^6.5.4",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/apibots-io/fabric-editor.git"
  },
  "author": "Apibots",
  "license": "UNLICENSED",
  "private": true
}
