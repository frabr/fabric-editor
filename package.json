{
  "name": "@frabr/fabric-editor",
  "version": "1.3.0",
  "description": "Fabric.js-based image editor with layers, clipping, and frame support",
  "imports": {
    "#fabric": {
      "node": "fabric/node",
      "default": "fabric"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.mjs",
      "require": "./dist/node.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "npm run test:node && npm run test:browser",
    "test:node": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "canvas": "^2.11.2",
    "fabric": "^6.5.4"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "jsdom": "^24.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/frabr/fabric-editor.git"
  },
  "author": "Apibots",
  "license": "UNLICENSED",
  "private": true
}
